# Asia Leader Tea - Environment Variables

# WhatsApp Number for Order Processing
# Format: Country code + phone number (without + or spaces)
# Example: 923229214000 for Pakistan
VITE_WHATSAPP_NUMBER="923229214000"

# Optional: Google Analytics Measurement ID
# Uncomment and set if you have Google Analytics
# VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Optional: App URL for absolute links
# Set this to your production domain
# VITE_APP_URL="https://asialeadertea.com"
